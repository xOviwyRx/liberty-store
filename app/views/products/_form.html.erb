<%= form_with model: product, class: "space-y-5" do |form| %>
  <% if product.errors.any? %>
    <div class="rounded-md bg-red-50 px-4 py-3 text-sm text-red-800">
      <ul class="list-disc space-y-1 pl-4">
        <% product.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, class: "block text-sm font-medium text-gray-700" %>
    <%= form.text_field :name, class: "mt-1 w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-gray-500 focus:outline-none" %>
  </div>

  <div>
    <%= form.label :description, class: "block text-sm font-medium text-gray-700" %>
    <%= form.rich_text_area :description, class: "mt-1 rounded-md border border-gray-300 bg-white text-sm" %>
  </div>

  <div>
    <%= form.label :featured_image, class: "block text-sm font-medium text-gray-700" %>
    <%= form.file_field :featured_image, accept: "image/*",
          class: "mt-1 block w-full text-sm text-gray-600 file:mr-3 file:rounded-md file:border-0 file:bg-gray-100 file:px-3 file:py-1.5 file:text-sm file:font-medium hover:file:bg-gray-200" %>
  </div>

  <div>
    <%= form.label :inventory_count, class: "block text-sm font-medium text-gray-700" %>
    <%= form.number_field :inventory_count, class: "mt-1 w-32 rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-gray-500 focus:outline-none" %>
  </div>

  <div class="flex items-center gap-3">
    <%= form.submit class: "rounded-md bg-gray-900 px-4 py-2 text-sm font-medium text-white hover:bg-gray-700 cursor-pointer" %>
    <%= link_to "Cancel", products_path, class: "rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium hover:bg-gray-50" %>
  </div>
<% end %>
