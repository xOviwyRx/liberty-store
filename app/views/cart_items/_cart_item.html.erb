<li id="<%= dom_id(cart_item) %>" class="flex items-center gap-4 p-4">
  <% if cart_item.product.featured_image.attached? %>
    <%= image_tag cart_item.product.featured_image.variant(resize_to_limit: [ 96, 96 ]), class: "h-12 w-12 rounded border border-gray-100 object-cover" %>
  <% end %>
  <div class="grow">
    <%= link_to cart_item.product.name, cart_item.product, class: "font-medium hover:underline" %>
    <p class="text-sm text-gray-500"><%= number_to_currency(cart_item.product.price) %> each</p>
  </div>
  <div class="flex items-center gap-1">
    <%= button_to "−", cart_item_path(cart_item), method: :patch,
          params: { cart_item: { quantity: cart_item.quantity - 1 } },
          disabled: cart_item.quantity <= 1,
          class: "h-7 w-7 rounded border border-gray-300 text-sm hover:bg-gray-50 cursor-pointer disabled:cursor-not-allowed disabled:text-gray-300 disabled:hover:bg-white" %>
    <span class="w-8 text-center text-sm"><%= cart_item.quantity %></span>
    <%= button_to "+", cart_item_path(cart_item), method: :patch,
          params: { cart_item: { quantity: cart_item.quantity + 1 } },
          disabled: cart_item.quantity >= cart_item.product.inventory_count,
          class: "h-7 w-7 rounded border border-gray-300 text-sm hover:bg-gray-50 cursor-pointer disabled:cursor-not-allowed disabled:text-gray-300 disabled:hover:bg-white" %>
  </div>
  <p class="w-24 text-right font-medium"><%= number_to_currency(cart_item.product.price * cart_item.quantity) %></p>
  <%= button_to "✕", cart_item_path(cart_item), method: :delete,
        data: { turbo_confirm: "Remove #{cart_item.product.name} from your cart?" },
        class: "ml-2 text-gray-400 hover:text-red-600 cursor-pointer" %>
</li>
