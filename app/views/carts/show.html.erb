<%= link_to "← Back to products", products_path, class: "text-sm text-gray-600 hover:text-gray-900" %>

<h1 class="mt-4 text-2xl font-bold tracking-tight">Your cart</h1>

<% if @cart_items.empty? %>
  <div class="mt-6 rounded-lg border border-gray-200 bg-white p-8 text-center">
    <p class="text-gray-600">Your cart is empty.</p>
    <%= link_to "Browse products", products_path, class: "mt-3 inline-block text-sm font-medium underline hover:text-gray-600" %>
  </div>
<% else %>
  <div class="mt-6 rounded-lg border border-gray-200 bg-white">
    <ul class="divide-y divide-gray-100">
      <% @cart_items.each do |item| %>
        <li class="flex items-center gap-4 p-4">
          <% if item.product.featured_image.attached? %>
            <%= image_tag item.product.featured_image.variant(resize_to_limit: [ 96, 96 ]), class: "h-12 w-12 rounded border border-gray-100 object-cover" %>
          <% end %>
          <div class="grow">
            <%= link_to item.product.name, item.product, class: "font-medium hover:underline" %>
            <p class="text-sm text-gray-500"><%= number_to_currency(item.product.price) %> each</p>
          </div>
          <div class="flex items-center gap-1">
            <%= button_to "−", cart_item_path(item), method: :patch,
                  params: { cart_item: { quantity: item.quantity - 1 } },
                  disabled: item.quantity <= 1,
                  class: "h-7 w-7 rounded border border-gray-300 text-sm hover:bg-gray-50 cursor-pointer disabled:cursor-not-allowed disabled:text-gray-300 disabled:hover:bg-white" %>
            <span class="w-8 text-center text-sm"><%= item.quantity %></span>
            <%= button_to "+", cart_item_path(item), method: :patch,
                  params: { cart_item: { quantity: item.quantity + 1 } },
                  class: "h-7 w-7 rounded border border-gray-300 text-sm hover:bg-gray-50 cursor-pointer" %>
          </div>
          <p class="w-24 text-right font-medium"><%= number_to_currency(item.product.price * item.quantity) %></p>
          <%= button_to "✕", cart_item_path(item), method: :delete,
                data: { turbo_confirm: "Remove #{item.product.name} from your cart?" },
                class: "ml-2 text-gray-400 hover:text-red-600 cursor-pointer" %>
        </li>
      <% end %>
    </ul>

    <div class="flex items-center justify-between border-t border-gray-200 p-4">
      <p class="font-medium">Total</p>
      <p class="text-lg font-semibold"><%= number_to_currency(current_cart.total) %></p>
    </div>
  </div>
<% end %>
