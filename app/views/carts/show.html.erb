<%= link_to "← Back to products", products_path, class: "text-sm text-gray-600 hover:text-gray-900" %>

<h1 class="mt-4 text-2xl font-bold tracking-tight">Your cart</h1>

<% if @cart_items.empty? %>
  <div class="mt-6 rounded-lg border border-gray-200 bg-white p-8 text-center">
    <p class="text-gray-600">Your cart is empty.</p>
    <%= link_to "Browse products", products_path, class: "mt-3 inline-block text-sm font-medium underline hover:text-gray-600" %>
  </div>
<% else %>
  <div class="mt-6 rounded-lg border border-gray-200 bg-white">
    <ul class="divide-y divide-gray-100">
      <%= render @cart_items %>
    </ul>

    <div class="flex items-center justify-between border-t border-gray-200 p-4">
      <p class="font-medium">Total</p>
      <p id="cart_total" class="text-lg font-semibold"><%= number_to_currency(current_cart.total) %></p>
    </div>
  </div>
<% end %>
