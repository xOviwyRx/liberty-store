<div class="mx-auto max-w-md">
  <h1 class="text-2xl font-bold tracking-tight">Sign in</h1>

  <div class="mt-6 rounded-lg border border-gray-200 bg-white p-6">
    <%= form_with url: session_path, class: "space-y-4" do |form| %>
      <div>
        <%= form.label :email_address, "Email address", class: "block text-sm font-medium text-gray-700" %>
        <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", value: params[:email_address],
              class: "mt-1 w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-gray-500 focus:outline-none" %>
      </div>

      <div>
        <%= form.label :password, class: "block text-sm font-medium text-gray-700" %>
        <%= form.password_field :password, required: true, autocomplete: "current-password", maxlength: 72,
              class: "mt-1 w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-gray-500 focus:outline-none" %>
      </div>

      <%= form.submit "Sign in", class: "w-full rounded-md bg-gray-900 px-4 py-2 text-sm font-medium text-white hover:bg-gray-700 cursor-pointer" %>
    <% end %>

    <%= link_to "Forgot password?", new_password_path, class: "mt-4 inline-block text-sm text-gray-600 hover:text-gray-900" %>
  </div>
</div>
